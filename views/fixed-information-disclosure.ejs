<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="LAB 2 Fixed: Information Disclosure – Versi Aman dengan filter response dan error handling yang benar." />
  <title><%= title %> | CyberLAB</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<%- include('partials/navbar') %>

<main class="main-content">

  <div class="page-header fixed-page-header">
    <div class="page-header-inner">
      <div class="lab-badge fixed-badge">✅ FIXED / SECURE VERSION</div>
      <h1>🔍 LAB 2 (Fixed): Information Disclosure – Versi Aman</h1>
      <p>Implementasi endpoint yang hanya mengembalikan data yang diperlukan, tanpa informasi sensitif.</p>
    </div>
  </div>

  <div class="lab-container">

    <!-- PERBEDAAN -->
    <section class="lab-section">
      <h2>🔄 Perbedaan dari Versi Vulnerable</h2>
      <div class="compare-grid">
        <div class="compare-box compare-vuln">
          <h4>⚠️ Versi Vulnerable</h4>
          <ul>
            <li>Semua field user dikembalikan</li>
            <li>Debug endpoint terbuka</li>
            <li>Stack trace dikirim ke user</li>
            <li>Secret key bocor di response</li>
          </ul>
        </div>
        <div class="compare-box compare-fixed">
          <h4>✅ Versi Fixed</h4>
          <ul>
            <li>Hanya nama & email dikembalikan</li>
            <li>Debug endpoint ditutup (403)</li>
            <li>Error message umum saja</li>
            <li>Detail error hanya di server log</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- SIMULASI FIXED ENDPOINT -->
    <section class="lab-section">
      <h2>🧪 Simulasi Endpoint Aman</h2>
      <div class="fixed-box">
        <div class="fixed-label">✅ Endpoint yang sudah diperbaiki:</div>

        <div class="endpoint-grid">

          <div class="endpoint-card endpoint-fixed-card">
            <div class="endpoint-method method-green">GET</div>
            <code>/lab/information-disclosure/fixed/profile</code>
            <p>Hanya mengembalikan nama dan email. Tidak ada field internal.</p>
            <button class="btn btn-fixed-sm" id="btn-profile-safe" onclick="fetchFixedEndpoint('/lab/information-disclosure/fixed/profile', 'profile')">
              ✅ Lihat Profile (Aman)
            </button>
          </div>

          <div class="endpoint-card endpoint-fixed-card">
            <div class="endpoint-method method-green">GET</div>
            <code>/lab/information-disclosure/fixed/debug</code>
            <p>Debug endpoint ditutup. Mengembalikan 403 Forbidden.</p>
            <button class="btn btn-fixed-sm" id="btn-debug-safe" onclick="fetchFixedEndpoint('/lab/information-disclosure/fixed/debug', 'debug')">
              ✅ Coba Debug Endpoint
            </button>
          </div>

          <div class="endpoint-card endpoint-fixed-card">
            <div class="endpoint-method method-green">GET</div>
            <code>/lab/information-disclosure/fixed/error</code>
            <p>Error hanya menampilkan pesan umum. Stack trace di server log.</p>
            <button class="btn btn-fixed-sm" id="btn-error-safe" onclick="fetchFixedEndpoint('/lab/information-disclosure/fixed/error', 'error')">
              ✅ Lihat Error (Aman)
            </button>
          </div>

        </div>

        <!-- RESPONSE OUTPUT -->
        <div class="response-output response-output-fixed" id="response-output-fixed" style="display:none;">
          <div class="response-header">
            <span id="response-endpoint-fixed"></span>
            <button onclick="document.getElementById('response-output-fixed').style.display='none'" class="btn-close-response">✕</button>
          </div>
          <pre id="response-data-fixed" class="response-pre"></pre>
        </div>

      </div>
    </section>

    <!-- PENJELASAN PENCEGAHAN -->
    <section class="lab-section">
      <h2>🛡️ Penjelasan Pencegahan</h2>
      <div class="fix-detail-grid">

        <div class="fix-detail-item">
          <div class="fix-num">1</div>
          <div>
            <strong>Matikan Debug Mode di Production</strong>
            <p>Set <code>NODE_ENV=production</code>. Jangan pernah biarkan debug mode aktif di server publik.</p>
          </div>
        </div>

        <div class="fix-detail-item">
          <div class="fix-num">2</div>
          <div>
            <strong>Filter Field Sensitif di Response API</strong>
            <p>Buat DTO (Data Transfer Object) atau pilih field secara eksplisit sebelum dikirim ke client.</p>
          </div>
        </div>

        <div class="fix-detail-item">
          <div class="fix-num">3</div>
          <div>
            <strong>Jangan Tampilkan Stack Trace ke User</strong>
            <p>Gunakan error handler global yang menampilkan pesan umum. Log detail error ke file/server log saja.</p>
          </div>
        </div>

        <div class="fix-detail-item">
          <div class="fix-num">4</div>
          <div>
            <strong>Jangan Simpan Secret di File Publik</strong>
            <p>Gunakan environment variables (<code>.env</code>) dan pastikan <code>.env</code> tidak di-commit ke git.</p>
          </div>
        </div>

        <div class="fix-detail-item">
          <div class="fix-num">5</div>
          <div>
            <strong>Access Control pada Endpoint Internal</strong>
            <p>Endpoint admin/debug harus dilindungi autentikasi dan hanya bisa diakses dari IP tertentu (internal network).</p>
          </div>
        </div>

        <div class="fix-detail-item">
          <div class="fix-num">6</div>
          <div>
            <strong>Security Headers</strong>
            <p>Tambahkan header seperti <code>X-Content-Type-Options</code>, <code>X-Frame-Options</code>, dan <code>Content-Security-Policy</code>.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- KODE IMPLEMENTASI -->
    <section class="lab-section">
      <h2>💻 Implementasi (Kode Penting)</h2>
      <div class="code-block">
        <div class="code-label">routes/informationDisclosure.js – Fixed Version</div>
        <pre><code>// ✅ Hanya kembalikan field yang diperlukan
router.get('/fixed/profile', (req, res) => {
  res.json({
    name: 'Rama',
    email: 'rama@example.com'
    // ✅ TIDAK ada: id, role, internalUserId, isAdmin, debugNote, token
  });
});

// ✅ Debug endpoint ditutup
router.get('/fixed/debug', (req, res) => {
  res.status(403).json({ error: 'Akses ditolak.' });
});

// ✅ Error handler aman
router.get('/fixed/error', (req, res) => {
  try {
    throw new TypeError('Simulated error');
  } catch (err) {
    console.error('[LOG]', err.stack); // ✅ Log ke server saja
    res.status(500).json({
      error: true,
      message: 'Terjadi kesalahan pada server.' // ✅ Pesan umum
    });
  }
});</code></pre>
      </div>
    </section>

    <!-- NAVIGASI -->
    <div class="nav-to-fixed">
      <a href="/lab/information-disclosure" class="btn btn-vuln-outline" id="btn-back-to-vuln-info">← Kembali ke Versi Vulnerable</a>
      <a href="/" class="btn btn-home" id="btn-home-from-fixed-info">🏠 Kembali ke Home</a>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

<script>
async function fetchFixedEndpoint(url, type) {
  const outputEl = document.getElementById('response-output-fixed');
  const dataEl = document.getElementById('response-data-fixed');
  const endpointEl = document.getElementById('response-endpoint-fixed');

  dataEl.textContent = '⏳ Memuat data...';
  outputEl.style.display = 'block';
  endpointEl.textContent = 'GET ' + url;

  try {
    const res = await fetch(url);
    const data = await res.json();
    dataEl.textContent = JSON.stringify(data, null, 2);
  } catch (err) {
    dataEl.textContent = 'Error: ' + err.message;
  }

  outputEl.scrollIntoView({ behavior: 'smooth' });
}
</script>
</body>
</html>
